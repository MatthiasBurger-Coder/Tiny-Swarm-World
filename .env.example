# Tiny Swarm World operator configuration template.
# Copy to .tiny-swarm-world/local/live-installation.env for local runs, or export
# the same keys in the process environment. Process environment values override
# values from the local file.

# Required setup secrets.
TSW_PORTAINER_ADMIN_PASSWORD="<replace-with-portainer-password>"
TSW_NEXUS_ADMIN_PASSWORD="<replace-with-nexus-password>"
TSW_JENKINS_ADMIN_PASSWORD="<replace-with-jenkins-password>"
TSW_SONARQUBE_ADMIN_PASSWORD="<replace-with-sonarqube-password>"
TSW_POSTGRES_PASSWORD="<replace-with-sonarqube-postgres-password>"
TSW_SONARQUBE_POSTGRES_PASSWORD="<replace-with-sonarqube-service-postgres-password>"
TSW_PULSAR_TOKEN_SECRET_KEY="<replace-with-generated-base64-signing-key>"
TSW_PULSAR_ADMIN_TOKEN="<replace-with-generated-jwt>"
TSW_PULSAR_MANAGER_ADMIN_PASSWORD="<replace-with-pulsar-manager-password>"

# Required Infisical bootstrap values for the service-access profile.
TSW_INFISICAL_LOGIN_EMAIL="<replace-with-infisical-admin-email>"
TSW_INFISICAL_BOOTSTRAP_ADMIN_PASSWORD="<replace-with-infisical-admin-password>"
TSW_INFISICAL_ENCRYPTION_KEY="<replace-with-infisical-encryption-key>"
TSW_INFISICAL_AUTH_SECRET="<replace-with-infisical-auth-secret>"
TSW_INFISICAL_POSTGRES_PASSWORD="<replace-with-infisical-postgres-password>"
TSW_INFISICAL_REDIS_PASSWORD="<replace-with-infisical-redis-password>"

# Optional deployment controls.
TSW_PORTAINER_STACK_REQUEST_TIMEOUT_SECONDS=180
TSW_SEED_INFISICAL_ITEMS=0
TSW_LXC_DOCKER_REGISTRY_MIRROR="http://registry-cache.example.invalid:5001"
TSW_PULSAR_ADMIN_URL="http://pulsar.example.invalid:8080"
TSW_PULSAR_PUBLIC_ADMIN_URL="http://pulsar-admin.example.invalid:8087"

# Optional Traefik Docker secret names.
TSW_TRAEFIK_TLS_CERT_SECRET_NAME="tsw_traefik_tls_cert"
TSW_TRAEFIK_TLS_KEY_SECRET_NAME="tsw_traefik_tls_key"
